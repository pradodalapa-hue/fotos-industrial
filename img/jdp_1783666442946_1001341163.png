
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>010 SUPERMERCADOS 010 - APP</title>
            <style>
                body, html { margin:0; padding:0; background:#000; height:100vh; overflow:hidden; }
                
        :root { 
            --gold: #ffd700; --bg: #0a0a0a; --panel: #111; 
            --blue: #00d2ff; --neon: #39ff14; --red: #ff4444;
        }

        body { 
            font-family: 'Segoe UI', sans-serif; background: var(--bg); color: white; 
            margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; 
        }

        .header-jdp { 
            background: #000; border-bottom: 3px solid var(--gold); padding: 12px; 
            text-align: center; color: var(--gold); font-weight: bold; letter-spacing: 2px;
            font-size: 14px;
        }

        .main-layout { display: grid; grid-template-columns: 350px 1fr; flex-grow: 1; }
        
        /* SIDEBAR INDUSTRIAL */
        .sidebar { background: var(--panel); padding: 20px; border-right: 1px solid #333; display: flex; flex-direction: column; gap: 15px; }
        .terminal { background: #000; color: var(--neon); font-family: monospace; font-size: 11px; padding: 10px; height: 100px; border: 1px solid #444; border-radius: 4px; overflow-y: auto; box-shadow: inset 0 0 10px #000; }
        
        .btn-industrial { background: var(--gold); color: black; border: none; padding: 12px; font-weight: bold; cursor: pointer; text-transform: uppercase; border-radius: 4px; width: 100%; transition: 0.2s; }
        .btn-industrial:hover { filter: brightness(1.2); transform: translateY(-2px); }
        .btn-industrial:active { transform: translateY(0); }

        /* ÁREA DO CELULAR */
        .preview-area { background: radial-gradient(circle, #1a1a1a, #000); display: flex; justify-content: center; align-items: center; }
        .phone-box { 
            width: 360px; height: 720px; background: #1a1a1a; border: 12px solid #222; 
            border-radius: 45px; position: relative; overflow: hidden; display: flex; flex-direction: column;
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
        }

        .nav-machine { 
            width: 100%; height: 65px; background: #000; display: flex; align-items: center; 
            justify-content: space-between; padding: 0 20px; z-index: 9999; border-bottom: 2px solid var(--gold); box-sizing: border-box; 
        }

        /* COMPONENTES DINÂMICOS */
        .screen-container { flex-grow: 1; width: 100%; position: relative; background: #111; cursor: crosshair; }
        .layer { position: absolute; width: 100%; height: 100%; display: none; top: 0; left: 0; }
        .layer.active { display: block; }
        .img-render { width: 100%; height: 100%; object-fit: contain; }

        .hotspot { 
            position: absolute; border: 1px solid rgba(255, 255, 255, 0.3); 
            background: rgba(255, 255, 255, 0.1); z-index: 100; border-radius: 8px; cursor: pointer;
        }

        /* ANIMAÇÃO CORAÇÃO VIBRANDO */
        @keyframes heartbeat {
            0% { transform: scale(1); box-shadow: 0 0 0px var(--blue); }
            50% { transform: scale(1.08); box-shadow: 0 0 20px var(--blue); }
            100% { transform: scale(1); box-shadow: 0 0 0px var(--blue); }
        }

        .heartbeat-active {
            animation: heartbeat 1.5s infinite ease-in-out;
            border: 2px solid var(--blue) !important;
            background: rgba(0, 210, 255, 0.2) !important;
        }

        .hotspot.editing { 
            border: 2px solid var(--neon) !important; 
            background: rgba(57, 255, 20, 0.3) !important;
            box-shadow: 0 0 15px var(--neon);
            z-index: 1000;
        }

        /* MODAL DE CONTROLE */
        .modal-jdp { 
            position: absolute; right: 20px; top: 80px; width: 320px; 
            background: #fff; color: #000; padding: 20px; border-radius: 12px; 
            border: 5px solid var(--gold); z-index: 10000; display: none; flex-direction: column; 
        }
        .choice-btn { background: #f0f0f0; border: 1px solid #ccc; padding: 12px; margin: 5px 0; border-radius: 8px; cursor: pointer; font-weight: bold; text-align: center; }
        .choice-btn:hover { background: #e0e0e0; }
    
                .sidebar, .header-jdp, .modal-jdp, #btn-vida { display: none !important; }
                .phone-box { width: 100vw !important; height: 100vh !important; border:none !important; border-radius:0 !important; }
                .hotspot { border:none !important; background:transparent !important; }
            </style>
        </head>
        <body>
            <div class="phone-box">
                <div class="nav-machine">
                    <button class="btn-leme" onclick="v()">⬅</button>
                    <button class="btn-leme" onclick="i()">🏠</button>
                </div>
                <div id="sc">
                <div class="layer active" id="layer-1"><img src="data:image/png;base64," class="img-render" onclick="marcarBotao(event)"><div class="hotspot" data-link="https://pradodalapa-hue.github.io/Novo-test/" style="left: 52.537%; top: 84.0661%; width: 15%; height: 8%;"></div></div>
            </div>
            </div>
            <script>
                document.querySelectorAll('.hotspot').forEach(h => {
                    if(h.dataset.target || h.dataset.link) h.classList.add('heartbeat-active');
                    h.onclick = function() {
                        if(this.dataset.target) g(this.dataset.target);
                        else if(this.dataset.link) window.open(this.dataset.link, '_blank');
                    }
                });
                let st = [1];
                function g(id) {
                    document.querySelectorAll('.layer').forEach(l => l.style.display='none');
                    document.getElementById('layer-'+id).style.display='block';
                    if(st[st.length-1] != id) st.push(id);
                }
                function v() { if(st.length>1) { st.pop(); g(st[st.length-1]); st.pop(); } }
                function i() { st=[1]; g(1); st.pop(); }
            </script>
        </body></html>